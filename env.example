# =============================================================================
# Delphi (synsc-context) — Environment Variables
# =============================================================================
# Copy this file to .env and customize as needed:
#   cp env.example .env
#
# For Docker Compose, most defaults work out of the box.
# =============================================================================

# =============================================================================
# DATABASE (Required)
# =============================================================================
# Option 1: Individual parts (recommended — keeps password separate)
POSTGRES_USER=synsc
POSTGRES_PASSWORD=change-me
POSTGRES_DB=synsc
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Option 2: Full URL (overrides individual parts if set)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# =============================================================================
# API SERVER
# =============================================================================
# SYNSC_API_HOST=0.0.0.0
# SYNSC_API_PORT=8742

# Require authentication for all API endpoints (default: false)
# SYNSC_REQUIRE_AUTH=true

# CORS origins (comma-separated)
# SYNSC_CORS_ORIGINS=http://localhost:3000

# =============================================================================
# FRONTEND
# =============================================================================
# Port for the Next.js frontend (used by launch_app.sh)
# FRONTEND_PORT=3000

# Frontend URL (used for OAuth redirect after login)
# FRONTEND_URL=http://localhost:3000

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Server secret for signing JWT session tokens (required)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SERVER_SECRET=change-me-generate-a-real-secret

# GitHub OAuth (recommended for multi-user)
# Create an OAuth App at: https://github.com/settings/developers
# Set callback URL to: http://localhost:3000/auth/github/callback
# (Use the frontend URL so the session cookie is set on the correct origin)
# GITHUB_CLIENT_ID=your_client_id
# GITHUB_CLIENT_SECRET=your_client_secret

# System password for admin fallback login (optional)
# SYSTEM_PASSWORD=change-me-to-something-secure

# API key for MCP stdio mode (used when connecting via CLI/IDE)
# Create one from the dashboard at /api-keys, then set it here
# SYNSC_API_KEY=your_api_key

# Token encryption key for GitHub PATs and HF tokens stored in DB (optional)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TOKEN_ENCRYPTION_KEY=your_fernet_key

# =============================================================================
# EMBEDDING CONFIGURATION
# =============================================================================
# Sentence-transformers model (runs locally, no API key needed)
# Recommended models:
#   jinaai/jina-embeddings-v2-base-code  — code-aware, 768 dim, 8K context (best for code)
#   all-mpnet-base-v2                    — general purpose, 768 dim, 384 token context
#   microsoft/unixcoder-base             — code + NL, 768 dim
#   codesage/codesage-small              — code-specific, 1024 dim (change EMBEDDING_DIMENSION too)
#   BAAI/bge-base-en-v1.5                — general retrieval, 768 dim
#   all-MiniLM-L6-v2                     — lightweight, 384 dim (change EMBEDDING_DIMENSION too)
EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-code

# Device for inference: cpu, cuda, mps (auto-detects GPU by default)
# EMBEDDING_DEVICE=cpu

# Batch size for embedding generation (auto-scales on CUDA based on VRAM)
# EMBEDDING_BATCH_SIZE=64

# Embedding dimension (must match model output and DB schema)
# Default 768 works for jina-code, mpnet, unixcoder, bge-base
# EMBEDDING_DIMENSION=768

# =============================================================================
# RERANKER (Optional — improves search quality)
# =============================================================================
# SYNSC_ENABLE_RERANKER=true
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# =============================================================================
# HUGGINGFACE (Optional — for dataset indexing)
# =============================================================================
# HF_TOKEN=hf_your_token_here

# =============================================================================
# STORAGE
# =============================================================================
# SYNSC_TEMP_DIR=/tmp/synsc-context

# =============================================================================
# LOGGING
# =============================================================================
# SYNSC_LOG_LEVEL=INFO
# Log format: "console" (default, human-readable) or "json" (machine-parseable)
# SYNSC_LOG_FORMAT=json

# =============================================================================
# SECURITY HEADERS
# =============================================================================
# Enable HSTS (Strict-Transport-Security) — only enable behind TLS termination
# SYNSC_ENABLE_HSTS=true

# =============================================================================
# CORS (fine-tuning)
# =============================================================================
# Allowed HTTP methods (comma-separated, default: GET,POST,DELETE,PUT,OPTIONS)
# SYNSC_CORS_METHODS=GET,POST,DELETE,PUT,OPTIONS
# Allowed headers (comma-separated, default: Authorization,Content-Type,X-API-Key)
# SYNSC_CORS_HEADERS=Authorization,Content-Type,X-API-Key

# =============================================================================
# RATE LIMITING
# =============================================================================
# SYNSC_RATE_LIMIT_ENABLED=true
# SYNSC_RATE_LIMIT_DEFAULT=60/minute
# SYNSC_RATE_LIMIT_AUTH=10/minute
# SYNSC_RATE_LIMIT_INDEX=5/minute
# SYNSC_RATE_LIMIT_SEARCH=30/minute

# =============================================================================
# WORKER
# =============================================================================
# SYNSC_WORKER_THREADS=4
# SYNSC_WORKER_POLL_INTERVAL=5

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# ENABLE_CODE_INDEXING=true
# ENABLE_PAPER_INDEXING=true
# ENABLE_DATASET_INDEXING=true
