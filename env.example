# =============================================================================
# Synsc Context - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp env.example .env
#
# For LOCAL development with Supabase:
#   ./launch_app.sh --local
#   (This auto-populates Supabase variables from local instance)
#
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/_/settings/api
#
# Supabase API Keys (2024+):
#   - Secret key (sb_secret_xxx): Server-side, bypasses RLS → use for backend
#   - Publishable key (sb_publishable_xxx): Client-side, uses RLS
#   - Legacy: service_role / anon keys still work

# Your Supabase project URL
# Cloud: https://your-project-id.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Secret Key (server-side only, bypasses RLS) - REQUIRED for backend
# Cloud: Dashboard → Settings → API → API Keys tab → Create new → Secret key
# Or use legacy: Dashboard → Settings → API → Legacy API Keys → service_role
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# Supabase Publishable Key (optional, for client-side if needed)
# Cloud: Dashboard → Settings → API → API Keys tab → Publishable key
# Or use legacy: Dashboard → Settings → API → Legacy API Keys → anon
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Supabase JWT Secret - REQUIRED for backend JWT signature verification
# Cloud: Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Direct PostgreSQL connection string - REQUIRED
# Cloud: Dashboard → Settings → Database → Connection string → URI
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# =============================================================================
# CODE EMBEDDING CONFIGURATION (Required for code context)
# =============================================================================
# Uses Google Gemini API for code embeddings
# Get your API key from: https://aistudio.google.com/apikey

GEMINI_API_KEY=your-gemini-api-key-here

# Embedding model (default: gemini-embedding-001)
# CODE_EMBEDDING_MODEL=gemini-embedding-001

# =============================================================================
# PAPER EMBEDDING CONFIGURATION (Required for paper context)
# =============================================================================
# Uses Hugging Face sentence-transformers for paper embeddings
# No API key required - runs locally

# Embedding model (default: sentence-transformers/all-mpnet-base-v2)
# PAPER_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Device for paper embeddings (cpu, cuda, mps)
# PAPER_EMBEDDING_DEVICE=cpu

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================

# Backend API host (default: 0.0.0.0)
# SYNSC_API_HOST=0.0.0.0

# Backend API port (default: 8742)
# SYNSC_API_PORT=8742

# Require API key authentication (default: true for production, false for local)
# SYNSC_REQUIRE_AUTH=false

# Allowed CORS origins (comma-separated). Default: http://localhost:3000
# In production, set this to your actual frontend domain(s):
# SYNSC_CORS_ORIGINS=https://app.synsc.dev,https://synsc.dev

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Frontend development port (default: 3000)
NEXT_PUBLIC_FRONTEND_PORT=3000

# Backend API URL for frontend
NEXT_PUBLIC_API_URL=http://localhost:8742

# Supabase client-side config (for Next.js direct Supabase access if needed)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key-here

# =============================================================================
# DATA STORAGE
# =============================================================================

# Base directory for data storage (default: ./data)
# SYNSC_DATA_DIR=./data

# Temp directory for cloning repos (default: /tmp/synsc-context)
# SYNSC_TEMP_DIR=/tmp/synsc-context

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# SYNSC_LOG_LEVEL=INFO

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================

# Number of parallel indexing workers (default: 4)
# SYNSC_WORKER_THREADS=4

# Job polling interval in seconds (default: 5)
# SYNSC_WORKER_POLL_INTERVAL=5

# =============================================================================
# DEVELOPMENT FLAGS
# =============================================================================

# Set to 'true' for local development
DEV_MODE=true

# Enable debug mode
# DEBUG=false
